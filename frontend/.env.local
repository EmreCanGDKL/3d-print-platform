NEXT_PUBLIC_API_URL=http://localhost:3001

# SQLite yolu prisma şema klasörüne göre çözülür (frontend/prisma → ../../backend/prisma/dev.db)
DATABASE_URL=file:../../backend/prisma/dev.db

# UploadThing — dashboard’dan tek satırlık token (aynısı genelde UPLOADTHING_SECRET olarak da geçer)
UPLOADTHING_TOKEN=

# İsteğe bağlı: katalog ürünü eklerken bu kullanıcıya bağlanır; yoksa veritabanındaki ilk kullanıcı kullanılır
MARKETPLACE_DEMO_USER_ID=